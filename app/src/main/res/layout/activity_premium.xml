<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent" android:layout_height="match_parent"
    android:background="#050508">
    <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
        android:orientation="vertical" android:gravity="center_horizontal"
        android:padding="20dp">

        <!-- Crown + Title -->
        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
            android:text="&#128081;" android:textSize="52sp"
            android:layout_marginTop="16dp" android:layout_marginBottom="6dp"/>
        <TextView android:text="@string/premium_full_title"
            android:layout_width="wrap_content" android:layout_height="wrap_content"
            android:textSize="26sp" android:textStyle="bold" android:textColor="#FFD700"
            android:letterSpacing="0.1" android:layout_marginBottom="4dp"/>
        <TextView android:text="@string/premium_brand"
            android:layout_width="wrap_content" android:layout_height="wrap_content"
            android:textSize="12sp" android:textColor="#333333" android:layout_marginBottom="8dp"/>
        <TextView android:id="@+id/tv_premium_status"
            android:layout_width="wrap_content" android:layout_height="wrap_content"
            android:text="@string/free_version" android:textSize="13sp"
            android:textColor="#666666" android:layout_marginBottom="4dp"/>
        <TextView android:id="@+id/tv_device_id"
            android:layout_width="wrap_content" android:layout_height="wrap_content"
            android:text="@string/device_id_label" android:textSize="10sp"
            android:textColor="#2A2A2A" android:layout_marginBottom="20dp"/>

        <!-- Price -->
        <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
            android:orientation="vertical" android:gravity="center"
            android:background="#0D0D10" android:padding="16dp" android:layout_marginBottom="16dp">
            <LinearLayout android:layout_width="wrap_content" android:layout_height="wrap_content"
                android:orientation="horizontal" android:gravity="bottom">
                <TextView android:text="$" android:layout_width="wrap_content"
                    android:layout_height="wrap_content" android:textSize="18sp"
                    android:textColor="#FFD700" android:textStyle="bold" android:paddingBottom="6dp"/>
                <TextView android:text="@string/price_premium"
                    android:layout_width="wrap_content" android:layout_height="wrap_content"
                    android:textSize="44sp" android:textStyle="bold" android:textColor="#FFD700"/>
                <TextView android:text="@string/price_per_year_suffix"
                    android:layout_width="wrap_content" android:layout_height="wrap_content"
                    android:textSize="16sp" android:textColor="#FFD700" android:textStyle="bold"
                    android:paddingBottom="8dp" android:paddingStart="2dp"/>
            </LinearLayout>
            <TextView android:text="@string/annual_plan"
                android:layout_width="wrap_content" android:layout_height="wrap_content"
                android:textSize="11sp" android:textColor="#444444"/>
        </LinearLayout>

        <!-- FREE vs PREMIUM -->
        <TextView android:text="@string/free_vs_full_header"
            android:layout_width="match_parent" android:layout_height="wrap_content"
            android:textSize="9sp" android:textColor="#CC0000" android:textStyle="bold"
            android:letterSpacing="0.2" android:layout_marginBottom="8dp"/>

        <!-- Free features -->
        <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
            android:orientation="vertical" android:background="#0D0D10"
            android:padding="14dp" android:layout_marginBottom="2dp">
            <TextView android:text="@string/free_included_header"
                android:layout_width="wrap_content" android:layout_height="wrap_content"
                android:textSize="10sp" android:textColor="#00AA44" android:textStyle="bold"
                android:layout_marginBottom="8dp"/>
            <TextView android:text="@string/free_feat1"
                android:layout_width="match_parent" android:layout_height="wrap_content"
                android:textSize="12sp" android:textColor="#555555" android:layout_marginBottom="4dp"/>
            <TextView android:text="@string/free_feat2"
                android:layout_width="match_parent" android:layout_height="wrap_content"
                android:textSize="12sp" android:textColor="#555555" android:layout_marginBottom="4dp"/>
            <TextView android:text="@string/free_feat3"
                android:layout_width="match_parent" android:layout_height="wrap_content"
                android:textSize="12sp" android:textColor="#555555"/>
        </LinearLayout>

        <!-- Premium features -->
        <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
            android:orientation="vertical" android:background="#1A1400"
            android:padding="14dp" android:layout_marginBottom="16dp">
            <TextView android:text="@string/premium_unlocks_header"
                android:layout_width="wrap_content" android:layout_height="wrap_content"
                android:textSize="10sp" android:textColor="#FFD700" android:textStyle="bold"
                android:layout_marginBottom="10dp"/>

            <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                android:orientation="horizontal" android:gravity="center_vertical" android:layout_marginBottom="8dp">
                <TextView android:text="&#128222;" android:layout_width="wrap_content"
                    android:layout_height="wrap_content" android:textSize="18sp" android:layout_marginEnd="10dp"/>
                <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:orientation="vertical">
                    <TextView android:text="@string/prem_feat1_title"
                        android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:textColor="#FFFFFF" android:textSize="13sp" android:textStyle="bold"/>
                    <TextView android:text="@string/prem_feat1_sub"
                        android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:textColor="#555555" android:textSize="11sp"/>
                </LinearLayout>
            </LinearLayout>

            <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                android:orientation="horizontal" android:gravity="center_vertical" android:layout_marginBottom="8dp">
                <TextView android:text="&#128247;" android:layout_width="wrap_content"
                    android:layout_height="wrap_content" android:textSize="18sp" android:layout_marginEnd="10dp"/>
                <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:orientation="vertical">
                    <TextView android:text="@string/prem_feat2_title"
                        android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:textColor="#FFFFFF" android:textSize="13sp" android:textStyle="bold"/>
                    <TextView android:text="@string/prem_feat2_sub"
                        android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:textColor="#555555" android:textSize="11sp"/>
                </LinearLayout>
            </LinearLayout>

            <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                android:orientation="horizontal" android:gravity="center_vertical" android:layout_marginBottom="8dp">
                <TextView android:text="&#128225;" android:layout_width="wrap_content"
                    android:layout_height="wrap_content" android:textSize="18sp" android:layout_marginEnd="10dp"/>
                <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:orientation="vertical">
                    <TextView android:text="@string/prem_feat3_title"
                        android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:textColor="#FFFFFF" android:textSize="13sp" android:textStyle="bold"/>
                    <TextView android:text="@string/prem_feat3_sub"
                        android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:textColor="#555555" android:textSize="11sp"/>
                </LinearLayout>
            </LinearLayout>

            <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                android:orientation="horizontal" android:gravity="center_vertical" android:layout_marginBottom="8dp">
                <TextView android:text="&#8987;" android:layout_width="wrap_content"
                    android:layout_height="wrap_content" android:textSize="18sp" android:layout_marginEnd="10dp"/>
                <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:orientation="vertical">
                    <TextView android:text="@string/prem_feat4_title"
                        android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:textColor="#FFFFFF" android:textSize="13sp" android:textStyle="bold"/>
                    <TextView android:text="@string/prem_feat4_sub"
                        android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:textColor="#555555" android:textSize="11sp"/>
                </LinearLayout>
            </LinearLayout>

            <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                android:orientation="horizontal" android:gravity="center_vertical" android:layout_marginBottom="8dp">
                <TextView android:text="&#128737;" android:layout_width="wrap_content"
                    android:layout_height="wrap_content" android:textSize="18sp" android:layout_marginEnd="10dp"/>
                <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:orientation="vertical">
                    <TextView android:text="@string/prem_feat5_title"
                        android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:textColor="#FFFFFF" android:textSize="13sp" android:textStyle="bold"/>
                    <TextView android:text="@string/prem_feat5_sub"
                        android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:textColor="#555555" android:textSize="11sp"/>
                </LinearLayout>
            </LinearLayout>

            <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                android:orientation="horizontal" android:gravity="center_vertical">
                <TextView android:text="&#11088;" android:layout_width="wrap_content"
                    android:layout_height="wrap_content" android:textSize="18sp" android:layout_marginEnd="10dp"/>
                <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:orientation="vertical">
                    <TextView android:text="@string/prem_feat6_title"
                        android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:textColor="#FFFFFF" android:textSize="13sp" android:textStyle="bold"/>
                    <TextView android:text="@string/prem_feat6_sub"
                        android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:textColor="#555555" android:textSize="11sp"/>
                </LinearLayout>
            </LinearLayout>
        </LinearLayout>

        <!-- PAYMENT METHODS -->
        <TextView android:text="@string/choose_payment_header"
            android:layout_width="match_parent" android:layout_height="wrap_content"
            android:textSize="9sp" android:textColor="#CC0000" android:textStyle="bold"
            android:letterSpacing="0.2" android:layout_marginBottom="10dp"/>

        <!-- Method 1: Card (Coming Soon) -->
        <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
            android:orientation="horizontal" android:gravity="center_vertical"
            android:background="#0D0D10" android:padding="14dp" android:layout_marginBottom="6dp">
            <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content"
                android:layout_weight="1" android:orientation="vertical">
                <LinearLayout android:layout_width="wrap_content" android:layout_height="wrap_content"
                    android:orientation="horizontal" android:gravity="center_vertical">
                    <TextView android:text="&#128179; Visa / MasterCard"
                        android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:textSize="14sp" android:textColor="#AAAAAA" android:textStyle="bold"
                        android:layout_marginEnd="8dp"/>
                    <TextView android:text="@string/coming_soon_badge"
                        android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:textSize="9sp" android:textColor="#CC0000" android:textStyle="bold"
                        android:background="#1A0000" android:padding="3dp"/>
                </LinearLayout>
                <TextView android:text="@string/card_payment_sub"
                    android:layout_width="wrap_content" android:layout_height="wrap_content"
                    android:textSize="11sp" android:textColor="#333333"/>
            </LinearLayout>
            <Button android:id="@+id/btn_pay_card"
                android:layout_width="80dp" android:layout_height="36dp"
                android:text="@string/soon_btn" android:textSize="11sp"
                android:backgroundTint="#1A1A1A" android:textColor="#333333"
                android:enabled="false"/>
        </LinearLayout>

        <!-- Method 2: Contact Support → Facebook -->
        <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
            android:orientation="horizontal" android:gravity="center_vertical"
            android:background="#0D0D10" android:padding="14dp" android:layout_marginBottom="16dp">
            <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content"
                android:layout_weight="1" android:orientation="vertical">
                <LinearLayout android:layout_width="wrap_content" android:layout_height="wrap_content"
                    android:orientation="horizontal" android:gravity="center_vertical">
                    <TextView android:text="&#128172; Contact Support"
                        android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:textSize="14sp" android:textColor="#AAAAAA" android:textStyle="bold"
                        android:layout_marginEnd="8dp"/>
                </LinearLayout>
                <TextView android:text="@string/contact_support_sub"
                    android:layout_width="wrap_content" android:layout_height="wrap_content"
                    android:textSize="11sp" android:textColor="#4A90D9"/>
            </LinearLayout>
            <Button android:id="@+id/btn_pay_support"
                android:layout_width="80dp" android:layout_height="36dp"
                android:text="@string/contact_btn"
                android:textSize="11sp"
                android:backgroundTint="#1A3A6A" android:textColor="#FFFFFF"
                android:enabled="true"/>
        </LinearLayout>

        <!-- LICENSE KEY -->
        <TextView android:text="@string/license_key_header"
            android:layout_width="match_parent" android:layout_height="wrap_content"
            android:textSize="9sp" android:textColor="#00AA44" android:textStyle="bold"
            android:letterSpacing="0.2" android:layout_marginBottom="8dp"/>

        <LinearLayout android:id="@+id/layout_license_input"
            android:layout_width="match_parent" android:layout_height="wrap_content"
            android:orientation="vertical" android:background="#0D1A0D"
            android:padding="14dp" android:layout_marginBottom="12dp">
            <TextView android:text="@string/license_key_hint"
                android:layout_width="match_parent" android:layout_height="wrap_content"
                android:textSize="10sp" android:textColor="#444444" android:layout_marginBottom="8dp"/>
            <EditText android:id="@+id/et_license_key"
                android:layout_width="match_parent" android:layout_height="wrap_content"
                android:hint="@string/license_key_placeholder"
                android:inputType="textPassword"
                android:textColor="#FFFFFF" android:textColorHint="#333333"
                android:fontFamily="monospace" android:textSize="14sp"/>
        </LinearLayout>

        <!-- Main CTA button -->
        <Button android:id="@+id/btn_buy"
            android:layout_width="match_parent" android:layout_height="54dp"
            android:text="@string/unlock_full"
            android:textSize="15sp" android:textStyle="bold"
            android:backgroundTint="#1A1300" android:textColor="#FFD700"
            android:layout_marginBottom="8dp"/>

        <Button android:id="@+id/btn_restore"
            android:layout_width="match_parent" android:layout_height="44dp"
            android:text="@string/get_device_id_btn"
            android:textSize="12sp" android:backgroundTint="#111111"
            android:textColor="#555555" android:layout_marginBottom="12dp"/>

        <!-- Copyright -->
        <TextView android:layout_width="match_parent" android:layout_height="wrap_content"
            android:text="@string/about_copyright"
            android:textSize="9sp" android:textColor="#222222"
            android:gravity="center" android:letterSpacing="0.1" android:layout_marginBottom="8dp"/>

        <Button android:id="@+id/btn_back_premium"
            android:layout_width="match_parent" android:layout_height="44dp"
            android:text="@string/back_arrow_left" android:textSize="13sp"
            android:backgroundTint="#1A1A1A" android:textColor="#666666"/>

        <!-- REVOKE LICENSE — shown only when premium active -->
        <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
            android:orientation="vertical" android:padding="20dp"
            android:layout_marginTop="8dp">
            <View android:layout_width="match_parent" android:layout_height="1dp"
                android:background="#1A1A1A" android:layout_marginBottom="16dp"/>
            <Button android:id="@+id/btn_revoke_license"
                android:layout_width="match_parent" android:layout_height="42dp"
                android:text="@string/revoke_license_btn"
                android:backgroundTint="#1A0000" android:textColor="#CC0000"
                android:textSize="12sp"/>
        </LinearLayout>

    </LinearLayout>
</ScrollView>
