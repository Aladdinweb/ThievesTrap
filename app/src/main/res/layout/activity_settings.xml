<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent" android:layout_height="match_parent"
    android:background="#050508">
    <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
        android:orientation="vertical" android:padding="16dp">

        <!-- Header -->
        <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
            android:orientation="horizontal" android:gravity="center_vertical"
            android:layout_marginBottom="20dp">
            <TextView android:text="@string/settings_title" android:layout_width="0dp"
                android:layout_height="wrap_content" android:layout_weight="1"
                android:textSize="18sp" android:textStyle="bold" android:textColor="#FFFFFF"/>
            <Button android:id="@+id/btn_back" android:layout_width="wrap_content"
                android:layout_height="36dp" android:text="@string/back_btn"
                android:backgroundTint="#CC0000" android:textColor="#FFFFFF" android:textSize="12sp"/>
        </LinearLayout>

        <!-- IDENTITY -->
        <TextView android:text="@string/section_identity"
            android:layout_width="match_parent" android:layout_height="wrap_content"
            android:textSize="10sp" android:textColor="#CC0000" android:textStyle="bold"
            android:background="#0D0D10" android:padding="10dp" android:layout_marginBottom="2dp"/>
        <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
            android:orientation="vertical" android:background="#0D0D10"
            android:padding="14dp" android:layout_marginBottom="12dp">
            <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                android:orientation="horizontal" android:gravity="center_vertical">
                <EditText android:id="@+id/et_imei" android:layout_width="0dp"
                    android:layout_height="wrap_content" android:layout_weight="1"
                    android:hint="IMEI (dial *#06#)" android:inputType="number"
                    android:textColor="#FFFFFF" android:textColorHint="#333333"/>
                <TextView android:id="@+id/tv_imei_hint" android:layout_width="wrap_content"
                    android:layout_height="wrap_content" android:text="&#8505;&#65039;"
                    android:textSize="18sp" android:textColor="#CC0000" android:padding="8dp"/>
            </LinearLayout>
            <Button android:id="@+id/btn_save_identity" android:layout_width="match_parent"
                android:layout_height="42dp" android:text="@string/save_btn"
                android:backgroundTint="#1A1A1A" android:textColor="#AAAAAA" android:layout_marginTop="10dp"/>
        </LinearLayout>

        <!-- EMERGENCY CONTACTS -->
        <TextView android:text="@string/section_contacts"
            android:layout_width="match_parent" android:layout_height="wrap_content"
            android:textSize="10sp" android:textColor="#CC0000" android:textStyle="bold"
            android:background="#0D0D10" android:padding="10dp" android:layout_marginBottom="2dp"/>
        <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
            android:orientation="vertical" android:background="#0D0D10"
            android:padding="14dp" android:layout_marginBottom="12dp">
            <EditText android:id="@+id/et_phone" android:layout_width="match_parent"
                android:layout_height="wrap_content" android:hint="Contact 1 (required)"
                android:inputType="phone" android:textColor="#FFFFFF"
                android:textColorHint="#333333" android:layout_marginBottom="8dp"/>
            <EditText android:id="@+id/et_phone2" android:layout_width="match_parent"
                android:layout_height="wrap_content" android:hint="Contact 2"
                android:inputType="phone" android:textColor="#FFFFFF"
                android:textColorHint="#333333" android:layout_marginBottom="8dp"/>
            <Button android:id="@+id/btn_save_contacts" android:layout_width="match_parent"
                android:layout_height="42dp" android:text="@string/save_contacts"
                android:backgroundTint="#1A1A1A" android:textColor="#AAAAAA"/>
        </LinearLayout>

        <!-- TELEGRAM ALERTS -->
        <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
            android:orientation="horizontal" android:gravity="center_vertical"
            android:background="#0D0D10" android:padding="10dp"
            android:layout_marginTop="10dp" android:layout_marginBottom="2dp">
            <TextView android:text="@string/telegram_section"
                android:layout_width="0dp" android:layout_height="wrap_content"
                android:layout_weight="1"
                android:textSize="9sp" android:textColor="#CC0000" android:textStyle="bold"
                android:letterSpacing="0.2"/>
            <TextView android:id="@+id/tv_telegram_premium_badge"
                android:layout_width="wrap_content" android:layout_height="wrap_content"
                android:text="@string/premium_lock" android:textSize="9sp"
                android:textColor="#555555" android:textStyle="bold"/>
        </LinearLayout>
        <LinearLayout android:id="@+id/layout_telegram_section"
            android:layout_width="match_parent" android:layout_height="wrap_content"
            android:orientation="vertical" android:background="#0D0D10"
            android:padding="14dp" android:layout_marginBottom="12dp">
            <!-- How to get Chat ID instruction card -->
            <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                android:orientation="vertical" android:background="#0A0A0D"
                android:padding="12dp" android:layout_marginBottom="10dp">
                <TextView android:text="@string/how_to_get_id"
                    android:layout_width="match_parent" android:layout_height="wrap_content"
                    android:textSize="11sp" android:textColor="#4A90D9" android:textStyle="bold"
                    android:layout_marginBottom="6dp"/>
                <TextView android:text="@string/tg_step1"
                    android:layout_width="match_parent" android:layout_height="wrap_content"
                    android:textSize="11sp" android:textColor="#888888" android:layout_marginBottom="3dp"/>
                <TextView android:text="@string/tg_step2"
                    android:layout_width="match_parent" android:layout_height="wrap_content"
                    android:textSize="11sp" android:textColor="#888888" android:layout_marginBottom="3dp"/>
                <TextView android:text="@string/tg_step3"
                    android:layout_width="match_parent" android:layout_height="wrap_content"
                    android:textSize="11sp" android:textColor="#888888" android:layout_marginBottom="3dp"/>
                <TextView android:text="@string/tg_step4"
                    android:layout_width="match_parent" android:layout_height="wrap_content"
                    android:textSize="11sp" android:textColor="#888888"/>
                <!-- Bot link button inside instruction card -->
                <Button android:id="@+id/btn_open_id_bot"
                    android:layout_width="match_parent" android:layout_height="40dp"
                    android:text="@string/tg_open_bot_btn"
                    android:backgroundTint="#1A2A1A" android:textColor="#00CC44"
                    android:textSize="12sp" android:layout_marginTop="10dp"/>
            </LinearLayout>

            <!-- Chat ID input -->
            <TextView android:text="@string/paste_chat_id"
                android:layout_width="match_parent" android:layout_height="wrap_content"
                android:textSize="10sp" android:textColor="#888888" android:layout_marginBottom="4dp"/>
            <EditText android:id="@+id/et_telegram_ids"
                android:layout_width="match_parent" android:layout_height="wrap_content"
                android:hint="123456789, 987654321"
                android:inputType="text" android:textColor="#FFFFFF"
                android:textColorHint="#333333" android:layout_marginBottom="10dp"
                android:focusable="false" android:clickable="true"/>

            <!-- Connect bot button -->
            <Button android:id="@+id/btn_setup_bot"
                android:layout_width="match_parent" android:layout_height="42dp"
                android:text="@string/connect_bot"
                android:backgroundTint="#1A1A2E" android:textColor="#4A90D9"
                android:textSize="12sp" android:layout_marginBottom="6dp"/>

            <!-- Share app link with contact -->
            <Button android:id="@+id/btn_share_app_tg"
                android:layout_width="match_parent" android:layout_height="42dp"
                android:text="@string/tg_share_app_btn"
                android:backgroundTint="#1A1A1A" android:textColor="#888888"
                android:textSize="12sp" android:layout_marginBottom="6dp"/>

            <!-- Share bot link with contact -->
            <Button android:id="@+id/btn_share_bot"
                android:layout_width="match_parent" android:layout_height="42dp"
                android:text="@string/tg_share_bot_btn"
                android:backgroundTint="#1A1A1A" android:textColor="#888888"
                android:textSize="12sp"/>
        </LinearLayout>

        <!-- THEFT ALERTS -->
        <TextView android:text="@string/theft_alerts_section"
            android:layout_width="match_parent" android:layout_height="wrap_content"
            android:textSize="10sp" android:textColor="#CC0000" android:textStyle="bold"
            android:background="#0D0D10" android:padding="10dp" android:layout_marginBottom="2dp"/>
        <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
            android:orientation="vertical" android:background="#0D0D10" android:layout_marginBottom="2dp">
            <LinearLayout android:layout_width="match_parent" android:layout_height="52dp"
                android:orientation="horizontal" android:gravity="center_vertical"
                android:paddingStart="14dp" android:paddingEnd="14dp">
                <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content"
                    android:layout_weight="1" android:orientation="vertical">
                    <TextView android:text="@string/sms_failed_label" android:layout_width="wrap_content"
                        android:layout_height="wrap_content" android:textColor="#DDDDDD" android:textSize="13sp"/>
                    <TextView android:text="@string/sms_failed_always" android:layout_width="wrap_content"
                        android:layout_height="wrap_content" android:textColor="#333333" android:textSize="10sp"/>
                </LinearLayout>
                <Switch android:id="@+id/sw_failed"
                    android:layout_width="wrap_content" android:layout_height="wrap_content"/>
            </LinearLayout>
        </LinearLayout>
        <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
            android:orientation="vertical" android:background="#0D0D10"
            android:padding="14dp" android:layout_marginBottom="12dp">
            <TextView android:text="@string/alert_after_n"
                android:layout_width="wrap_content" android:layout_height="wrap_content"
                android:textColor="#666666" android:textSize="11sp" android:layout_marginBottom="4dp"/>
            <Spinner android:id="@+id/spinner_failed" android:layout_width="match_parent"
                android:layout_height="46dp" android:background="#111111"/>
        </LinearLayout>

        <!-- SMART GRACE PERIOD -->
        <TextView android:text="@string/grace_section"
            android:layout_width="match_parent" android:layout_height="wrap_content"
            android:textSize="10sp" android:textColor="#CC0000" android:textStyle="bold"
            android:background="#0D0D10" android:padding="10dp" android:layout_marginBottom="2dp"/>
        <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
            android:orientation="vertical" android:background="#0D0D10"
            android:padding="14dp" android:layout_marginBottom="12dp">
            <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                android:orientation="horizontal" android:gravity="center_vertical"
                android:layout_marginBottom="8dp">
                <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content"
                    android:layout_weight="1" android:orientation="vertical">
                    <TextView android:text="@string/grace_toggle_label"
                        android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:textColor="#FFFFFF" android:textSize="13sp" android:textStyle="bold"/>
                    <TextView android:text="@string/grace_wrong_pin"
                        android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:textColor="#444444" android:textSize="11sp"/>
                </LinearLayout>
                <Switch android:id="@+id/sw_grace_enabled"
                    android:layout_width="wrap_content" android:layout_height="wrap_content"/>
            </LinearLayout>
            <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                android:orientation="horizontal" android:gravity="center_vertical"
                android:layout_marginBottom="8dp">
                <TextView android:text="@string/grace_5s" android:layout_width="wrap_content"
                    android:layout_height="wrap_content" android:textColor="#444444"
                    android:textSize="11sp" android:layout_marginEnd="8dp"/>
                <SeekBar android:id="@+id/seekbar_grace" android:layout_width="0dp"
                    android:layout_height="wrap_content" android:layout_weight="1"
                    android:max="55" android:progress="5"
                    android:progressTint="#CC0000" android:thumbTint="#CC0000"/>
                <TextView android:text="@string/grace_60s" android:layout_width="wrap_content"
                    android:layout_height="wrap_content" android:textColor="#444444"
                    android:textSize="11sp" android:layout_marginStart="8dp"/>
            </LinearLayout>
            <TextView android:id="@+id/tv_grace_value" android:layout_width="match_parent"
                android:layout_height="wrap_content" android:text="@string/grace_off_label"
                android:textColor="#444444" android:textSize="12sp" android:gravity="center"/>
        </LinearLayout>

        <!-- DEVICE STATUS ALERTS — airplane mode COMPLETELY REMOVED (v2.7.6) -->
        <TextView android:text="@string/device_status_section"
            android:layout_width="match_parent" android:layout_height="wrap_content"
            android:textSize="10sp" android:textColor="#CC0000" android:textStyle="bold"
            android:background="#0D0D10" android:padding="10dp" android:layout_marginBottom="2dp"/>
        <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
            android:orientation="vertical" android:background="#0D0D10" android:layout_marginBottom="12dp">

            <!-- Selfie on failed attempts — Premium -->
            <LinearLayout android:layout_width="match_parent" android:layout_height="50dp"
                android:orientation="horizontal" android:gravity="center_vertical"
                android:paddingStart="14dp" android:paddingEnd="14dp" android:layout_marginBottom="1dp">
                <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content"
                    android:layout_weight="1" android:orientation="vertical">
                    <TextView android:text="@string/selfie_label" android:layout_width="wrap_content"
                        android:layout_height="wrap_content" android:textColor="#DDDDDD" android:textSize="13sp"/>
                    <TextView android:text="@string/selfie_sub_tg" android:layout_width="wrap_content"
                        android:layout_height="wrap_content" android:textColor="#333333" android:textSize="10sp"/>
                </LinearLayout>
                <Switch android:id="@+id/sw_selfie"
                    android:layout_width="wrap_content" android:layout_height="wrap_content"/>
            </LinearLayout>

            <!-- SMS on SIM change — Premium -->
            <LinearLayout android:layout_width="match_parent" android:layout_height="50dp"
                android:orientation="horizontal" android:gravity="center_vertical"
                android:paddingStart="14dp" android:paddingEnd="14dp" android:layout_marginBottom="1dp">
                <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content"
                    android:layout_weight="1" android:orientation="vertical">
                    <TextView android:text="@string/sim_change_label" android:layout_width="wrap_content"
                        android:layout_height="wrap_content" android:textColor="#DDDDDD" android:textSize="13sp"/>
                    <TextView android:text="@string/sim_premium_label" android:layout_width="wrap_content"
                        android:layout_height="wrap_content" android:textColor="#333333" android:textSize="10sp"/>
                </LinearLayout>
                <Switch android:id="@+id/sw_sim"
                    android:layout_width="wrap_content" android:layout_height="wrap_content"/>
            </LinearLayout>

            <!-- Silent mode — Premium (airplane mode row DELETED here) -->
            <LinearLayout android:layout_width="match_parent" android:layout_height="50dp"
                android:orientation="horizontal" android:gravity="center_vertical"
                android:paddingStart="14dp" android:paddingEnd="14dp" android:layout_marginBottom="1dp">
                <TextView android:text="@string/silent_mode_label" android:layout_width="0dp"
                    android:layout_height="wrap_content" android:layout_weight="1"
                    android:textColor="#DDDDDD" android:textSize="13sp"/>
                <Switch android:id="@+id/sw_silent"
                    android:layout_width="wrap_content" android:layout_height="wrap_content"/>
            </LinearLayout>

        </LinearLayout>

        <!-- REMOTE CONTROL -->
        <TextView android:text="@string/remote_section"
            android:layout_width="match_parent" android:layout_height="wrap_content"
            android:textSize="10sp" android:textColor="#CC0000" android:textStyle="bold"
            android:background="#0D0D10" android:padding="10dp" android:layout_marginBottom="2dp"/>
        <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
            android:orientation="vertical" android:background="#0D0D10"
            android:padding="14dp" android:layout_marginBottom="12dp">
            <TextView android:text="@string/ping_note"
                android:layout_width="match_parent" android:layout_height="wrap_content"
                android:textSize="11sp" android:textColor="#4A90D9" android:lineSpacingMultiplier="1.3"/>
        </LinearLayout>

        <!-- NOTIFICATIONS -->
        <TextView android:text="@string/notifications_section"
            android:layout_width="match_parent" android:layout_height="wrap_content"
            android:textSize="9sp" android:textColor="#CC0000" android:textStyle="bold"
            android:background="#0D0D10" android:padding="10dp"
            android:layout_marginTop="10dp" android:layout_marginBottom="2dp"/>
        <LinearLayout android:layout_width="match_parent" android:layout_height="52dp"
            android:orientation="horizontal" android:gravity="center_vertical"
            android:background="#0D0D10" android:paddingStart="14dp" android:paddingEnd="14dp"
            android:layout_marginBottom="12dp">
            <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content"
                android:layout_weight="1" android:orientation="vertical">
                <TextView android:text="@string/notif_status_label"
                    android:layout_width="wrap_content" android:layout_height="wrap_content"
                    android:textColor="#FFFFFF" android:textSize="13sp" android:textStyle="bold"/>
                <TextView android:text="@string/notif_status_sub"
                    android:layout_width="wrap_content" android:layout_height="wrap_content"
                    android:textColor="#444444" android:textSize="11sp"/>
            </LinearLayout>
            <Switch android:id="@+id/sw_notif_enabled"
                android:layout_width="wrap_content" android:layout_height="wrap_content"/>
        </LinearLayout>

        <!-- SECURITY / TEST -->
        <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
            android:orientation="vertical" android:background="#0D0D10"
            android:padding="14dp" android:layout_marginBottom="12dp">
            <Button android:id="@+id/btn_test_sms" android:layout_width="match_parent"
                android:layout_height="44dp" android:text="@string/test_sms"
                android:backgroundTint="#1A1A1A" android:textColor="#AAAAAA"/>
        </LinearLayout>

        <!-- APP INFO -->
        <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
            android:orientation="vertical" android:background="#0D0D10"
            android:padding="14dp" android:layout_marginBottom="12dp">
            <TextView android:id="@+id/tv_version" android:layout_width="wrap_content"
                android:layout_height="wrap_content" android:textColor="#333333"
                android:textSize="12sp" android:layout_marginBottom="3dp"/>
            <TextView android:id="@+id/tv_total_alerts" android:layout_width="wrap_content"
                android:layout_height="wrap_content" android:textColor="#333333"
                android:textSize="12sp" android:layout_marginBottom="3dp"/>
            <TextView android:id="@+id/tv_last_alert_info" android:layout_width="wrap_content"
                android:layout_height="wrap_content" android:textColor="#333333"
                android:textSize="12sp" android:layout_marginBottom="10dp"/>
            <Button android:id="@+id/btn_reset_stats" android:layout_width="match_parent"
                android:layout_height="42dp" android:text="@string/reset_stats"
                android:backgroundTint="#0D0D0D" android:textColor="#333333"/>
        </LinearLayout>

        <!-- COPYRIGHT -->
        <TextView android:layout_width="match_parent" android:layout_height="wrap_content"
            android:text="@string/copyright_text"
            android:textSize="9sp" android:textColor="#1A1A1A"
            android:gravity="center" android:padding="12dp"/>

    </LinearLayout>
</ScrollView>
