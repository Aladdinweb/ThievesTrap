<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent" android:layout_height="wrap_content"
    android:orientation="horizontal" android:gravity="center_vertical"
    android:background="#0D0D10" android:padding="12dp"
    android:layout_marginBottom="2dp">
    <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content"
        android:layout_weight="1" android:orientation="vertical">
        <TextView android:id="@+id/tv_cmd_text" android:layout_width="wrap_content"
            android:layout_height="wrap_content" android:text="WHERE"
            android:textSize="14sp" android:textColor="#FFFFFF" android:textStyle="bold"
            android:fontFamily="monospace"/>
        <TextView android:id="@+id/tv_cmd_desc" android:layout_width="wrap_content"
            android:layout_height="wrap_content" android:text="Get current GPS location"
            android:textSize="11sp" android:textColor="#444444"/>
    </LinearLayout>
    <Button android:id="@+id/btn_copy_cmd" android:layout_width="64dp"
        android:layout_height="34dp" android:text="COPY" android:textSize="11sp"
        android:textStyle="bold" android:backgroundTint="#1A0000" android:textColor="#CC0000"/>
</LinearLayout>
