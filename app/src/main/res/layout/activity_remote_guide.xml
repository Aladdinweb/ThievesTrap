<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent" android:layout_height="match_parent"
    android:orientation="vertical" android:background="#050508">

    <!-- Header -->
    <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
        android:orientation="horizontal" android:gravity="center_vertical"
        android:background="#0D0D10" android:padding="16dp">
        <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content"
            android:layout_weight="1" android:orientation="vertical">
            <TextView android:text="@string/remote_title"
                android:layout_width="wrap_content" android:layout_height="wrap_content"
                android:textSize="16sp" android:textStyle="bold" android:textColor="#FFFFFF"/>
            <TextView android:text="@string/remote_sub"
                android:layout_width="wrap_content" android:layout_height="wrap_content"
                android:textSize="11sp" android:textColor="#444444"/>
        </LinearLayout>
        <Button android:id="@+id/btn_back_guide" android:layout_width="wrap_content"
            android:layout_height="36dp" android:text="@string/back_arrow" android:textSize="12sp"
            android:backgroundTint="#CC0000" android:textColor="#FFFFFF"/>
    </LinearLayout>

    <ScrollView android:layout_width="match_parent" android:layout_height="0dp"
        android:layout_weight="1">
        <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
            android:orientation="vertical" android:padding="16dp">

            <!-- INFO BOX -->
            <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                android:orientation="vertical" android:background="#0D1A0D"
                android:padding="14dp" android:layout_marginBottom="16dp">
                <TextView android:text="@string/how_to_use_title"
                    android:layout_width="wrap_content" android:layout_height="wrap_content"
                    android:textSize="10sp" android:textColor="#00AA44" android:textStyle="bold"
                    android:layout_marginBottom="6dp"/>
                <TextView android:text="@string/how_to_use_body"
                    android:layout_width="match_parent" android:layout_height="wrap_content"
                    android:textSize="11sp" android:textColor="#555555"
                    android:lineSpacingMultiplier="1.5"/>
            </LinearLayout>

            <!-- SECTION: LOCATION -->
            <TextView android:text="@string/cmd_location_section"
                android:layout_width="wrap_content" android:layout_height="wrap_content"
                android:textSize="10sp" android:textColor="#CC0000" android:textStyle="bold"
                android:letterSpacing="0.1" android:layout_marginBottom="8dp"/>

            <include layout="@layout/item_command" android:id="@+id/cmd_where"/>
            <include layout="@layout/item_command" android:id="@+id/cmd_history"/>

            <TextView android:text="@string/cmd_device_section"
                android:layout_width="wrap_content" android:layout_height="wrap_content"
                android:textSize="10sp" android:textColor="#CC0000" android:textStyle="bold"
                android:letterSpacing="0.1" android:layout_marginTop="12dp"
                android:layout_marginBottom="8dp"/>

            <include layout="@layout/item_command" android:id="@+id/cmd_info"/>
            <include layout="@layout/item_command" android:id="@+id/cmd_status"/>
            <include layout="@layout/item_command" android:id="@+id/cmd_battery"/>
            <include layout="@layout/item_command" android:id="@+id/cmd_imei"/>
            <include layout="@layout/item_command" android:id="@+id/cmd_sim"/>

            <TextView android:text="@string/cmd_security_section"
                android:layout_width="wrap_content" android:layout_height="wrap_content"
                android:textSize="10sp" android:textColor="#CC0000" android:textStyle="bold"
                android:letterSpacing="0.1" android:layout_marginTop="12dp"
                android:layout_marginBottom="8dp"/>

            <include layout="@layout/item_command" android:id="@+id/cmd_alarm"/>
            <include layout="@layout/item_command" android:id="@+id/cmd_stop_alarm"/>
            <include layout="@layout/item_command" android:id="@+id/cmd_lock"/>
            <include layout="@layout/item_command" android:id="@+id/cmd_selfie"/>

            <TextView android:text="@string/cmd_tracking_section"
                android:layout_width="wrap_content" android:layout_height="wrap_content"
                android:textSize="10sp" android:textColor="#CC0000" android:textStyle="bold"
                android:letterSpacing="0.1" android:layout_marginTop="12dp"
                android:layout_marginBottom="8dp"/>

            <include layout="@layout/item_command" android:id="@+id/cmd_ping2"/>
            <include layout="@layout/item_command" android:id="@+id/cmd_ping5"/>
            <include layout="@layout/item_command" android:id="@+id/cmd_stop_ping"/>

            <TextView android:text="@string/cmd_control_section"
                android:layout_width="wrap_content" android:layout_height="wrap_content"
                android:textSize="10sp" android:textColor="#CC0000" android:textStyle="bold"
                android:letterSpacing="0.1" android:layout_marginTop="12dp"
                android:layout_marginBottom="8dp"/>

            <include layout="@layout/item_command" android:id="@+id/cmd_active"/>
            <include layout="@layout/item_command" android:id="@+id/cmd_deactivate"/>
            <include layout="@layout/item_command" android:id="@+id/cmd_disarm"/>

        </LinearLayout>
    </ScrollView>
</LinearLayout>
